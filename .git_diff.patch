+/*
+ * --- Big Sur Theme (macOS-style) ---
+ * Applies frosted translucent surfaces, vibrant radial backgrounds,
+ * and system font stack for a more native macOS Big Sur look.
+ */
+.bigsur body {
+  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Inter', system-ui, sans-serif;
+}
+
+/* Background: soft vibrant radial gradients inspired by Big Sur */
+.bigsur-bg {
+  background-image:
+    radial-gradient(1200px 700px at 20% -10%, rgba(255, 255, 255, 0.35), transparent 60%),
+    radial-gradient(900px 500px at 90% 0%, rgba(10, 132, 255, 0.22), transparent 60%),
+    radial-gradient(1000px 500px at 10% 100%, rgba(255, 105, 180, 0.16), transparent 60%),
+    linear-gradient(180deg, rgba(245, 247, 250, 0.85), rgba(240, 244, 249, 0.75));
+}
+
+.dark .bigsur-bg {
+  background-image:
+    radial-gradient(1200px 700px at 20% -10%, rgba(255, 255, 255, 0.08), transparent 60%),
+    radial-gradient(900px 500px at 90% 0%, rgba(10, 132, 255, 0.18), transparent 60%),
+    radial-gradient(1000px 500px at 10% 100%, rgba(255, 105, 180, 0.12), transparent 60%),
+    linear-gradient(180deg, rgba(2, 6, 23, 0.9), rgba(15, 23, 42, 0.85));
+}
+
+/* Generic Big Sur surface for optional use */
+.bigsur-surface {
+  background: rgba(255, 255, 255, 0.66);
+  border: 1px solid rgba(255, 255, 255, 0.35);
+  border-radius: 1.25rem;
+  backdrop-filter: saturate(180%) blur(22px);
+  -webkit-backdrop-filter: saturate(180%) blur(22px);
+  box-shadow: 0 30px 80px -40px rgba(15, 23, 42, 0.35);
+}
+.dark .bigsur-surface {
+  background: rgba(2, 6, 23, 0.55);
+  border: 1px solid rgba(148, 163, 184, 0.28);
+}
+
+/* Elevate existing glass-effect to feel closer to macOS */
+.bigsur .glass-effect {
+  background:
+    radial-gradient(circle at 18% 18%, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0)),
+    linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.08));
+  border-color: rgba(255, 255, 255, 0.38);
+  backdrop-filter: saturate(200%) blur(var(--glass-blur, 20px));
+  border-radius: 1rem; /* WhiteSur-like rounded corners */
+}
+.bigsur.dark .glass-effect {
+  background:
+    radial-gradient(circle at 18% 18%, rgba(148, 180, 255, 0.2), rgba(148, 180, 255, 0)),
+    linear-gradient(135deg, rgba(8, 14, 26, 0.76), rgba(8, 14, 26, 0.4));
+  border-color: rgba(148, 163, 184, 0.32);
+}
+
+/*
+* --- Theme Toggling ---
+ * Applies the main theme colors to the body based on the class.
+ */
+.light body {
+  background-color: var(--color-bg-primary);
+  color: var(--color-text-primary);
+}
+
+.dark-theme {
+  background: linear-gradient(to right, #000000, #434343);
+  color: #ffffff;
+}
+
+/* Respect users who prefer reduced motion */
+@media (prefers-reduced-motion: reduce) {
+  html:focus-within {
+    scroll-behavior: auto;
+  }
+  *, *::before, *::after {
+    animation-duration: 0.001ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.001ms !important;
+    scroll-behavior: auto !important;
+  }
+}
