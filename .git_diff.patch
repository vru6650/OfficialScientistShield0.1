+/*
+ * --- Liquid Glass Global Theme ---
+ * makeOS-style translucency and fluid lighting across the app.
+ */
+html.liquid-glass body {
+  background: var(--macos-wallpaper);
+  color: var(--color-text-primary);
+}
+
+html.liquid-glass body::before {
+  background:
+    var(--macos-aurora-primary),
+    var(--macos-aurora-secondary),
+    var(--macos-horizon),
+    var(--liquid-caustic);
+  opacity: var(--app-body-overlay-opacity, 0.94);
+  filter: blur(20px) saturate(160%) brightness(1.02);
+}
+
+html.liquid-glass body::after {
+  background-image:
+    linear-gradient(120deg, color-mix(in srgb, var(--macos-grid-color) 60%, transparent) 1px, transparent 1px),
+    linear-gradient(0deg, color-mix(in srgb, var(--macos-grid-color) 52%, transparent) 1px, transparent 1px),
+    radial-gradient(24% 18% at 50% 18%, var(--glass-sheen), transparent 60%);
+  background-size: 120px 120px, 120px 120px, 220% 160%;
+  opacity: var(--app-body-grid-opacity, 0.32);
+  mix-blend-mode: soft-light;
+}
+
+html.liquid-glass .macos-desktop::before {
+  background:
+    var(--macos-waves),
+    var(--macos-aurora-primary),
+    var(--macos-aurora-secondary),
+    var(--liquid-caustic);
+  opacity: calc(var(--app-body-overlay-opacity, 0.7) * 0.75);
+  filter: saturate(140%);
+}
+
+html.liquid-glass .macos-desktop::after {
+  background:
+    var(--macos-horizon),
+    radial-gradient(520px 320px at 50% 0%, var(--macos-orb-top), transparent 70%);
+  opacity: 0.42;
+  mix-blend-mode: screen;
+}
+
+html.liquid-glass :where(.glass-effect, .card-surface) {
+  border-color: var(--liquid-border);
+  box-shadow: var(--liquid-shadow);
+  outline-color: color-mix(in srgb, var(--color-accent) 28%, transparent);
+}
+
+html.liquid-glass :where(input[type="text"], input[type="email"], input[type="password"], input[type="search"], input[type="url"], input[type="number"], textarea, select) {
+  background-color: var(--liquid-surface-soft);
+  border-color: var(--liquid-border);
+  box-shadow:
+    inset 0 1px 0 var(--liquid-highlight),
+    var(--liquid-shadow-soft);
+  color: var(--color-text-primary);
+  backdrop-filter: var(--liquid-backdrop);
+  -webkit-backdrop-filter: var(--liquid-backdrop);
+  transition: border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease;
+}
