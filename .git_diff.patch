+/*
+ * ========================================
+ * Global Component Styles
+ * ========================================
+ */
+
+/*
+ * --- Animated Gradient ---
+ * Reusable animation for subtle background gradients.
+ */
+.animated-gradient {
+  background-size: 200% 200%;
+  animation: gradient-animation 10s ease infinite;
+}
+
+@keyframes gradient-animation {
+  0% {
+    background-position: 0% 50%;
+  }
+  50% {
+    background-position: 100% 50%;
+  }
+  100% {
+    background-position: 0% 50%;
+  }
+}
+
+/* --- Glassmorphism Effect --- */
+.glass-effect {
+  background:
+    radial-gradient(120% 120% at 10% 20%, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0)),
+    linear-gradient(145deg, rgba(255, 255, 255, 0.24), rgba(255, 255, 255, 0.08));
+  backdrop-filter: saturate(200%) blur(var(--glass-blur, 18px));
+  border: 1px solid rgba(255, 255, 255, calc(var(--glass-border-alpha, 0.32)));
+  border-radius: 1.1rem;
+  box-shadow: var(--macos-glass-shadow, 0 30px 80px -40px rgba(15, 23, 42, 0.45));
+  outline: 1px solid rgba(90, 208, 255, 0.14);
+}
+
+.dark .glass-effect {
+  background:
+    radial-gradient(120% 120% at 16% 18%, rgba(110, 160, 230, 0.24), rgba(110, 160, 230, 0)),
+    linear-gradient(145deg, rgba(6, 12, 24, 0.7), rgba(8, 14, 28, 0.48));
+  border: 1px solid rgba(120, 150, 200, calc(var(--glass-border-alpha, 0.32)));
+  box-shadow: var(--macos-glass-shadow, 0 30px 80px -40px rgba(0, 0, 0, 0.6));
+  outline: 1px solid rgba(93, 210, 255, 0.12);
+}
+
+/*
+ * --- Post Content Styling ---
+ * Defines the typography and layout for content generated by a rich text editor.
+ */
+.post-content {
+  line-height: 1.75;
+}
+
+.post-content p {
+  margin-bottom: var(--paragraph-spacing, 1.25em);
+  line-height: inherit;
+  word-wrap: break-word;
+}
+
+.post-content h1,
+.post-content h2,
+.post-content h3,
+.post-content h4,
+.post-content h5,
+.post-content h6 {
+  font-weight: 700;
+  line-height: 1.2;
